from sklearn.metrics import precision_score, recall_score, f1_score, accuracy_score, roc_auc_score
import numpy as np

# Train XGBoost
xgb_model = xgb.XGBClassifier(
    n_estimators=200,
    max_depth=3,
    learning_rate=0.05,
    subsample=0.8,
    colsample_bytree=0.7,
    min_child_weight=3,
    scale_pos_weight=5,
    reg_alpha=0.1,
    reg_lambda=1,
    use_label_encoder=False,
    eval_metric='logloss',
    random_state=42
)
xgb_model.fit(X_train_res, y_train_res)

# Probabilities
y_test_proba = xgb_model.predict_proba(X_test)[:, 1]
y_train_proba = xgb_model.predict_proba(X_train_res)[:, 1]

# Function to find threshold for ~60:40 recall:precision
def find_threshold(proba, y_true, target_ratio=0.6):
    best_thresh = 0.5
    best_diff = float('inf')
    for thresh in np.arange(0.1, 0.9, 0.01):
        y_pred = (proba >= thresh).astype(int)
        recall = recall_score(y_true, y_pred)
        precision = precision_score(y_true, y_pred)
        ratio = recall / (recall + precision)
        diff = abs(ratio - target_ratio)
        if diff < best_diff:
            best_diff = diff
            best_thresh = thresh
    return best_thresh

# Find optimal threshold
optimal_thresh = find_threshold(y_test_proba, y_test, target_ratio=0.6)
print(f"Optimal Threshold: {optimal_thresh:.2f}")

# Apply threshold
y_train_pred = (y_train_proba >= optimal_thresh).astype(int)
y_test_pred = (y_test_proba >= optimal_thresh).astype(int)

# Training metrics
print("Training Performance")
print(f"Accuracy: {accuracy_score(y_train_res, y_train_pred):.4f}")
print(f"F1 Score: {f1_score(y_train_res, y_train_pred):.4f}")
print(f"Precision: {precision_score(y_train_res, y_train_pred):.4f}")
print(f"Recall: {recall_score(y_train_res, y_train_pred):.4f}")
print(f"ROC AUC: {roc_auc_score(y_train_res, y_train_pred):.4f}")
print("-----------------------------------")

# Test metrics
print("Test Performance")
print(f"Accuracy: {accuracy_score(y_test, y_test_pred):.4f}")
print(f"F1 Score: {f1_score(y_test, y_test_pred):.4f}")
print(f"Precision: {precision_score(y_test, y_test_pred):.4f}")
print(f"Recall: {recall_score(y_test, y_test_pred):.4f}")
print(f"ROC AUC: {roc_auc_score(y_test, y_test_pred):.4f}")

# Recall:Precision ratio
recall_val = recall_score(y_test, y_test_pred)
precision_val = precision_score(y_test, y_test_pred)
ratio = recall_val / (recall_val + precision_val)
print(f"Recall:Precision ratio: {recall_val:.2f}:{precision_val:.2f} ≈ {ratio*100:.0f}% recall contribution")




